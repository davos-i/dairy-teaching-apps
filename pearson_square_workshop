function updateBullSummary() {
  // Only run if the summary elements exist (step 8 is active)
  if (!document.getElementById('sum_hay_pct')) return;

  // Read whatever the student has entered so far — blank = show dash
  const hayRaw = document.getElementById('b_hay_final').value;
  const rbRaw  = document.getElementById('b_rb_final').value;
  const wcsRaw = document.getElementById('b_wcs_total').value;

  const hay = parseFloat(hayRaw);
  const rb  = parseFloat(rbRaw);
  const wcs = parseFloat(wcsRaw);

  const hayCp=6, rbCp=14, wcsCp=22;
  const hayMe=8, rbMe=9,  wcsMe=15;
  function f2(v){ return isNaN(v) ? '—' : v.toFixed(2); }
  function f1(v){ return isNaN(v) ? '—' : v.toFixed(1)+'%'; }

  // Ingredient rows
  document.getElementById('sum_hay_pct').textContent = f1(hay);
  document.getElementById('sum_rb_pct').textContent  = f1(rb);
  document.getElementById('sum_wcs_pct').textContent = f1(wcs);

  const hayCpC = isNaN(hay) ? NaN : hay/100 * hayCp;
  const rbCpC  = isNaN(rb)  ? NaN : rb/100  * rbCp;
  const wcsCpC = isNaN(wcs) ? NaN : wcs/100 * wcsCp;

  document.getElementById('sum_hay_cp').textContent = f2(hayCpC)+(isNaN(hayCpC)?'':'%');
  document.getElementById('sum_rb_cp').textContent  = f2(rbCpC)+(isNaN(rbCpC)?'':'%');
  document.getElementById('sum_wcs_cp').textContent = f2(wcsCpC)+(isNaN(wcsCpC)?'':'%');

  const hayMeC = isNaN(hay) ? NaN : hay/100 * hayMe;
  const rbMeC  = isNaN(rb)  ? NaN : rb/100  * rbMe;
  const wcsMeC = isNaN(wcs) ? NaN : wcs/100 * wcsMe;

  document.getElementById('sum_hay_me').textContent = isNaN(hayMeC) ? '—' : hayMeC.toFixed(2)+' MJ/kg DM';
  document.getElementById('sum_rb_me').textContent  = isNaN(rbMeC)  ? '—' : rbMeC.toFixed(2)+' MJ/kg DM';
  document.getElementById('sum_wcs_me').textContent = isNaN(wcsMeC) ? '—' : wcsMeC.toFixed(2)+' MJ/kg DM';

  // Totals — only show when all three are entered
  const allEntered = !isNaN(hay) && !isNaN(rb) && !isNaN(wcs);
  const total   = allEntered ? hay + rb + wcs : NaN;
  const totalCp = allEntered ? hayCpC + rbCpC + wcsCpC : NaN;
  const totalMe = allEntered ? hayMeC + rbMeC + wcsMeC : NaN;

  const totalCell = document.getElementById('sum_total_pct');
  totalCell.textContent = isNaN(total) ? '—' : total.toFixed(1)+'%';
  totalCell.style.color = isNaN(total) ? '' : (Math.abs(total-100)<=2 ? 'var(--correct)' : 'var(--error)');
  document.getElementById('sum_total_cp').textContent = isNaN(totalCp) ? '—' : totalCp.toFixed(2)+'% CP';
  document.getElementById('sum_total_me').textContent = isNaN(totalMe) ? '—' : totalMe.toFixed(2)+' MJ/kg DM';

  // Targets panel — only when all entered
  const targEl = document.getElementById('sum_targets');
  if (allEntered) {
    const cpOk = Math.abs(totalCp - 14) <= 1.0;
    const meOk = Math.abs(totalMe - 11) <= 0.5;
    targEl.innerHTML =
      '<strong>Nutrient targets check:</strong><br>' +
      (cpOk ? '\u2713' : '\u2717') + ' CP = '+totalCp.toFixed(2)+'% &nbsp;(target: 14%) ' + (cpOk ? '\u2014 met \u2713' : '\u2014 check your calculations') + '<br>' +
      (meOk ? '\u2713' : '\u2717') + ' ME = '+totalMe.toFixed(2)+' MJ/kg DM &nbsp;(target: 11 MJ/kg DM) ' + (meOk ? '\u2014 met \u2713' : '\u2014 check your calculations') + '<br>' +
      '\u2211 Total inclusion = '+total.toFixed(1)+'% &nbsp;' + (Math.abs(total-100)<=2 ? '(sums to ~100% \u2713)' : '(should sum to ~100% \u2014 recheck your values)');
    targEl.style.display = 'block';
    targEl.style.background = (cpOk && meOk) ? 'var(--correct-light)' : 'var(--error-light)';
    targEl.style.borderLeftColor = (cpOk && meOk) ? 'var(--correct)' : 'var(--error)';
    targEl.style.color = (cpOk && meOk) ? 'var(--correct)' : 'var(--error)';
  } else {
    targEl.style.display = 'none';
  }
}

