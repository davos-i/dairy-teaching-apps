    // Hide all tab panes except the one being printed
    document.querySelectorAll('.tab-pane').forEach(function(p) {
      p.classList.add('print-hide');
    });
    const paneId = which === 'mare' ? 'pane-mare' : 'pane-bull';
    document.getElementById(paneId).classList.remove('print-hide');

    // Trigger browser print
    window.print();

    // Restore after print dialog closes
    setTimeout(function() {
      document.querySelectorAll('.tab-pane').forEach(function(p) {
        p.classList.remove('print-hide');
      });
    }, 1000);
  }

</script>
</body>
</html>
