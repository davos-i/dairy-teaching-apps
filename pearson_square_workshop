<script>
// ═══════════════════════════════════════════
// WORKED EXAMPLE REVEAL
// ═══════════════════════════════════════════
let wRevealStep = 1; // step 1 already visible
function revealWorkedStep() {
  wRevealStep++;
  const el = document.getElementById('w-step' + wRevealStep);
  if (el) {
    el.style.display = 'block';
    el.scrollIntoView({behavior:'smooth', block:'start'});
  }
  if (wRevealStep >= 4) {
    document.getElementById('w-reveal-btn').style.display = 'none';
  }
}

// ═══════════════════════════════════════════
// STATE
// ═══════════════════════════════════════════
const stepChecks = {
  worked: {},
  mare: {
    1: { req: ['m_chaff_af','m_chaff_dm','m_pellet_af','m_pellet_dm'], done: new Set() },
    2: { req: ['m_dmi'], done: new Set() },
    3: { req: ['m_de_req','m_de_meets'], done: new Set() },
    4: { req: ['m_cp_req','m_cp_between'], done: new Set() },
    5: { req: ['m_sq'], done: new Set() },  // m_A checked inside checkMareSquare
    6: { req: ['m_pct_pellet','m_pct_chaff'], done: new Set() },
    7: { req: ['m_pellet_kgdm','m_pellet_af2','m_chaff_kgdm','m_chaff_af2'], done: new Set() },
    8: { req: ['m_cost_pellet','m_cost_chaff','m_cost_total'], done: new Set() }
  },
  bull: {
    1: { req: ['b_sq1_B_ok'], done: new Set() },
    2: { req: ['b1_sq'], done: new Set() },
    3: { req: ['b_wcs1_pct','b_hay1_pct','b_mix1_cp_ok'], done: new Set() },
    4: { req: ['b2_sq'], done: new Set() },
    5: { req: ['b_wcs2_pct','b_rb2_pct','b_mix2_cp_ok'], done: new Set() },
    6: { req: ['b3_sq'], done: new Set() },
    7: { req: ['b_mix1_pct','b_mix2_pct'], done: new Set() },
    8: { req: ['b_hay_final','b_rb_final','b_wcs_m1','b_wcs_m2','b_wcs_total'], done: new Set() },
    9: { req: ['b_dmi','b_hay_af','b_rb_af','b_wcs_af','b_cost'], done: new Set() }
  }
};

const tabProgress = { worked:0, mare:0, bull:0 };
const tabTotals   = { worked:0, mare:8, bull:9 };

function updateProg(tab) {
  const pct = Math.round((tabProgress[tab] / tabTotals[tab]) * 100);
  const el = document.getElementById('prog-' + tab);
  if (el) el.style.width = pct + '%';
}

function markDone(key, tab, step) {
  if (!tab || !step) return;
  const sc = stepChecks[tab][step];
  if (!sc) return;
  sc.done.add(key);
  const allDone = sc.req.every(r => sc.done.has(r));
  if (allDone) {
    const btn = document.getElementById(
      tab==='worked' ? 'wnext'+step : tab==='mare' ? 'mnext'+step : 'bnext'+step
    );
    if (btn) btn.disabled = false;
  }
}

// ═══════════════════════════════════════════
// GENERIC CHECKERS
// ═══════════════════════════════════════════
function checkNum(id, correct, tol, fbId, expl, tab, step) {
  const inp = document.getElementById(id);
  const fb  = document.getElementById(fbId);
  const val = parseFloat(inp.value);
  if (isNaN(val)) { showFb(fb,'err','Please enter a number.'); return; }
  if (Math.abs(val - correct) <= tol) {
    inp.classList.remove('wrong'); inp.classList.add('correct'); inp.disabled = true;
    showFb(fb,'ok','✓ Correct! ' + expl);
    markDone(id, tab, step);
  } else {
    inp.classList.remove('correct'); inp.classList.add('wrong');
    inp.classList.add('shake'); setTimeout(()=>inp.classList.remove('shake'),400);
    showFb(fb,'err','✗ Not quite — check your calculation and try again.');
  }
}

function checkSel(id, correct, fbId, okMsg, errMsg) {
  const sel = document.getElementById(id);
  const fb  = document.getElementById(fbId);
  if (!sel.value) { showFb(fb,'err','Please make a selection.'); return; }
  if (sel.value === correct) {
    sel.disabled = true; showFb(fb,'ok','✓ ' + okMsg);
    // derive tab/step from fbId
    const key = id + '_ok';
    // brute-force find which tab/step owns this select
    for (const [tab, steps] of Object.entries(stepChecks)) {
      for (const [step, sc] of Object.entries(steps)) {
        if (sc.req.includes(key) || sc.req.includes(id)) {
          markDone(sc.req.includes(key) ? key : id, tab, parseInt(step));
        }
      }
    }
  } else {
    showFb(fb,'err','✗ ' + errMsg);
  }
}

function showFb(el, type, msg) {
  el.className = 'feedback show ' + type;
  el.innerHTML = msg;
}

function toggleHint(id) {
  const el = document.getElementById(id);
  el.style.display = el.style.display === 'none' ? 'block' : 'none';
}

// ═══════════════════════════════════════════
// PEARSON SQUARE CHECKERS
// ═══════════════════════════════════════════
function checkMix1CP() {
  // First update table display with entered %s
  const wPct = parseFloat(document.getElementById('b_wcs1_pct').value);
  const hPct = parseFloat(document.getElementById('b_hay1_pct').value);
  if (!isNaN(wPct)) document.getElementById('b_wcs1_pct_show').textContent = wPct.toFixed(1) + '%';
  if (!isNaN(hPct)) document.getElementById('b_hay1_pct_show').textContent = hPct.toFixed(1) + '%';

  const wContrib = parseFloat(document.getElementById('b_wcs1_cp_contrib').value);
  const hContrib = parseFloat(document.getElementById('b_hay1_cp_contrib').value);
  const total    = parseFloat(document.getElementById('b_mix1_cp').value);
  const fb = document.getElementById('b_mix1_cp_fb');

  if (isNaN(wPct) || isNaN(hPct)) { showFb(fb,'err','✗ Enter % of WCS and % of hay in Mix 1 first.'); return; }
  if (isNaN(wContrib)||isNaN(hContrib)||isNaN(total)) { showFb(fb,'err','✗ Fill in all three rows of the table.'); return; }

  const expWC = wPct/100 * 22;
  const expHC = hPct/100 * 6;
  const expTotal = expWC + expHC;
  const tol = 0.4;

  const wcOk = Math.abs(wContrib - expWC) <= tol;
  const hcOk = Math.abs(hContrib - expHC) <= tol;
  const totOk = Math.abs(total - expTotal) <= tol;

  function mf(id,ok){const el=document.getElementById(id);el.classList.remove('correct','wrong');el.classList.add(ok?'correct':'wrong');if(!ok){el.classList.add('shake');setTimeout(()=>el.classList.remove('shake'),400);}}
  mf('b_wcs1_cp_contrib',wcOk); mf('b_hay1_cp_contrib',hcOk); mf('b_mix1_cp',totOk);

  if (wcOk&&hcOk&&totOk) {
    showFb(fb,'ok','✓ Correct! Mix 1 CP = '+expTotal.toFixed(1)+'% — this is the CP content of Mix 1 (balanced for ME but not yet for CP).');
    markDone('b_mix1_cp_ok','bull',3);
  } else {
    let msg = '✗ ';
    if (!wcOk) msg += 'WCS contribution: ('+wPct.toFixed(1)+'% ÷ 100) × 22% CP. ';
    if (!hcOk) msg += 'Hay contribution: ('+hPct.toFixed(1)+'% ÷ 100) × 6% CP. ';
    if (!totOk) msg += 'Total = sum of both contributions. ';
    showFb(fb,'err',msg.trim());
  }
}

function checkMix2CP() {
  const wPct = parseFloat(document.getElementById('b_wcs2_pct').value);
  const rPct = parseFloat(document.getElementById('b_rb2_pct').value);
  if (!isNaN(wPct)) document.getElementById('b_wcs2_pct_show').textContent = wPct.toFixed(1) + '%';
  if (!isNaN(rPct)) document.getElementById('b_rb2_pct_show').textContent = rPct.toFixed(1) + '%';

  const wContrib = parseFloat(document.getElementById('b_wcs2_cp_contrib').value);
  const rContrib = parseFloat(document.getElementById('b_rb2_cp_contrib').value);
  const total    = parseFloat(document.getElementById('b_mix2_cp').value);
  const fb = document.getElementById('b_mix2_cp_fb');

  if (isNaN(wPct) || isNaN(rPct)) { showFb(fb,'err','✗ Enter % of WCS and % of rice bran in Mix 2 first.'); return; }
  if (isNaN(wContrib)||isNaN(rContrib)||isNaN(total)) { showFb(fb,'err','✗ Fill in all three rows of the table.'); return; }

  const expWC = wPct/100 * 22;
  const expRC = rPct/100 * 14;
  const expTotal = expWC + expRC;
  const tol = 0.4;

  const wcOk = Math.abs(wContrib - expWC) <= tol;
  const rcOk = Math.abs(rContrib - expRC) <= tol;
  const totOk = Math.abs(total - expTotal) <= tol;

  function mf(id,ok){const el=document.getElementById(id);el.classList.remove('correct','wrong');el.classList.add(ok?'correct':'wrong');if(!ok){el.classList.add('shake');setTimeout(()=>el.classList.remove('shake'),400);}}
  mf('b_wcs2_cp_contrib',wcOk); mf('b_rb2_cp_contrib',rcOk); mf('b_mix2_cp',totOk);

  if (wcOk&&rcOk&&totOk) {
    showFb(fb,'ok','✓ Correct! Mix 2 CP = '+expTotal.toFixed(1)+'% — above the 14% target, while Mix 1 was below it. Now we can balance them in Square 3.');
    markDone('b_mix2_cp_ok','bull',5);
  } else {
    let msg = '✗ ';
    if (!wcOk) msg += 'WCS contribution: ('+wPct.toFixed(1)+'% ÷ 100) × 22% CP. ';
    if (!rcOk) msg += 'Rice bran contribution: ('+rPct.toFixed(1)+'% ÷ 100) × 14% CP. ';
    if (!totOk) msg += 'Total = sum of both contributions. ';
    showFb(fb,'err',msg.trim());
  }
}

function checkSquareGeneric(dId, eId, fId, fbId, dAns, eAns, fAns, tol, doneKey, tab, step) {
  const D = parseFloat(document.getElementById(dId).value);
  const E = parseFloat(document.getElementById(eId).value);
  const F = parseFloat(document.getElementById(fId).value);
  const fb = document.getElementById(fbId);
  const dOk = !isNaN(D) && Math.abs(D-dAns)<=tol;
  const eOk = !isNaN(E) && Math.abs(E-eAns)<=tol;
  const fOk = !isNaN(F) && Math.abs(F-fAns)<=tol;
  function mark(id, ok) {
    const el = document.getElementById(id);
    el.classList.remove('correct','wrong');
    el.classList.add(ok?'correct':'wrong');
    if (ok) el.disabled=true;
    else { el.classList.add('shake'); setTimeout(()=>el.classList.remove('shake'),400); }
  }
  mark(dId,dOk); mark(eId,eOk); mark(fId,fOk);
  if (dOk&&eOk&&fOk) {
    showFb(fb,'ok','✓ All correct! D='+dAns+', E='+eAns+', F='+fAns+'.');
    markDone(doneKey, tab, step);
  } else {
    let msg='✗ ';
    if(!dOk) msg+='Box D=|A−C|='+dAns+'. ';
    if(!eOk) msg+='Box E=|B−A|='+eAns+'. ';
    if(!fOk) msg+='Box F=D+E='+fAns+'. ';
    showFb(fb,'err',msg.trim());
  }
}

// worked example is now reveal-only
function checkMareSquare() {
  // Check Box A first
  const A = parseFloat(document.getElementById('m_A').value);
  const fb = document.getElementById('m_sq_fb');
  if (isNaN(A)) { showFb(fb,'err','✗ Fill in Box A (your required CP%) before checking.'); return; }
  if (Math.abs(A - 6.5) > 0.3) {
    document.getElementById('m_A').classList.add('wrong');
    document.getElementById('m_A').classList.add('shake');
    setTimeout(()=>document.getElementById('m_A').classList.remove('shake'),400);
    showFb(fb,'err','✗ Box A is not correct — go back to Step 4 and use your calculated CP requirement.');
    return;
  }
  document.getElementById('m_A').classList.remove('wrong'); document.getElementById('m_A').classList.add('correct');
  // Now check D, E, F — but don\'t reveal answers on wrong
  const D = parseFloat(document.getElementById('m_D').value);
  const E = parseFloat(document.getElementById('m_E').value);
