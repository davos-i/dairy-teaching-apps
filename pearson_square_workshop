function checkNumAndPopulate(inputId, correctVal, tol, fbId, explanation, tab, step, tableCellId) {
  const inp = document.getElementById(inputId);
  const fb  = document.getElementById(fbId);
  const val = parseFloat(inp.value);
  if (isNaN(val)) { showFb(fb,'err','Please enter a number.'); return; }
  if (Math.abs(val - correctVal) <= tol) {
    inp.classList.remove('wrong'); inp.classList.add('correct'); inp.disabled = true;
    showFb(fb,'ok','\u2713 Correct! ' + explanation);
    markDone(inputId, tab, step);
    const cell = document.getElementById(tableCellId);
    if (cell) { cell.textContent = val.toFixed(1) + '%'; cell.style.fontWeight='600'; cell.style.color='var(--correct)'; }
  } else {
    inp.classList.remove('correct'); inp.classList.add('wrong');
    inp.classList.add('shake'); setTimeout(()=>inp.classList.remove('shake'),400);
    showFb(fb,'err','\u2717 Not quite \u2014 check your calculation and try again.');
  }
}

function checkFree() {
  const A=parseFloat(document.getElementById('free_A').value);
  const B=parseFloat(document.getElementById('free_B').value);
  const C=parseFloat(document.getElementById('free_C').value);
  const D=parseFloat(document.getElementById('free_D').value);
  const E=parseFloat(document.getElementById('free_E').value);
  const F=parseFloat(document.getElementById('free_F').value);
  const fb=document.getElementById('free_fb');
  if (isNaN(A)||isNaN(B)||isNaN(C)) { showFb(fb,'err','✗ Fill in Box A, B and C first.'); return; }

  if (isNaN(D)||isNaN(E)||isNaN(F)) { showFb(fb,'err','✗ Fill in D, E and F before checking.'); return; }
  const cD=Math.abs(A-C), cE=Math.abs(B-A), cF=cD+cE, tol=0.15;
  const dOk=Math.abs(D-cD)<=tol, eOk=Math.abs(E-cE)<=tol, fOk=Math.abs(F-cF)<=tol;
  function mf(id,ok){const el=document.getElementById(id);el.classList.remove('correct','wrong');el.classList.add(ok?'correct':'wrong');if(!ok){el.classList.add('shake');setTimeout(()=>el.classList.remove('shake'),400);}}
  mf('free_D',dOk); mf('free_E',eOk); mf('free_F',fOk);
  if (dOk&&eOk&&fOk) {
    const lB=document.getElementById('free_label_B').value||'Ingredient B';
    const lC=document.getElementById('free_label_C').value||'Ingredient C';
    const pctB = (cD/cF*100).toFixed(1);
    const pctC = (cE/cF*100).toFixed(1);
    showFb(fb,'ok',
      '\u2713 Correct!<br><br>' +
      '<strong>Working:</strong><br>' +
      'Parts of '+lB+' (Box D) = '+cD.toFixed(2)+'<br>' +
      'Parts of '+lC+' (Box E) = '+cE.toFixed(2)+'<br>' +
      'Total parts (Box F) = '+cF.toFixed(2)+'<br><br>' +
      '<strong>Proportions:</strong><br>' +
      lB+': '+cD.toFixed(2)+' ÷ '+cF.toFixed(2)+' × 100 = <strong>'+pctB+'%</strong><br>' +
      lC+': '+cE.toFixed(2)+' ÷ '+cF.toFixed(2)+' × 100 = <strong>'+pctC+'%</strong>'
    );
  } else {
    let msg='✗ ';
    if(!dOk) msg+='D=|A−C|='+cD.toFixed(2)+'. ';
    if(!eOk) msg+='E=|B−A|='+cE.toFixed(2)+'. ';
    if(!fOk) msg+='F=D+E='+cF.toFixed(2)+'. ';
    showFb(fb,'err',msg.trim());
  }
}

