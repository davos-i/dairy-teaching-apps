<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pearson Square – Ration Formulation</title>
<link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;1,400&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #f5f0e8;
  --card: #fffdf8;
  --border: #d4c9b0;
  --text: #2a2318;
  --muted: #7a6e5f;
  --accent: #3d6b4f;
  --accent2: #8b4513;
  --accent-light: #e8f0eb;
  --error: #b54a2a;
  --error-light: #fdf0ec;
  --correct: #2d6a4f;
  --correct-light: #eaf4ee;
  --highlight: #c9a84c;
  --highlight-light: #fdf6e3;
  --line: #5a8c72;
  --tab-h: 54px;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;}

/* ── HEADER ── */
.header{background:var(--accent);color:#fff;padding:22px 32px 18px;border-bottom:4px solid var(--highlight);position:relative;overflow:hidden;}
.header::before{content:'';position:absolute;right:-60px;top:-60px;width:220px;height:220px;border-radius:50%;background:rgba(255,255,255,0.05);}
.header-inner{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;position:relative;}
.header h1{font-family:'Lora',serif;font-size:1.5rem;font-weight:600;letter-spacing:-0.01em;}
.header p{font-size:0.85rem;opacity:0.82;margin-top:3px;}
.teach-btn{background:rgba(255,255,255,0.15);border:1.5px solid rgba(255,255,255,0.4);color:#fff;padding:7px 15px;border-radius:6px;font-family:'DM Sans',sans-serif;font-weight:600;font-size:0.8rem;cursor:pointer;white-space:nowrap;transition:background .2s;}
.teach-btn:hover{background:rgba(255,255,255,0.25);}

/* ── TEACH BANNER ── */
#teachBanner{display:none;background:#7a3a10;color:#fff;padding:9px 24px;font-size:0.84rem;font-weight:600;align-items:center;gap:14px;justify-content:space-between;}
.teach-exit{background:rgba(255,255,255,0.2);border:none;color:#fff;padding:4px 11px;border-radius:5px;cursor:pointer;font-family:'DM Sans',sans-serif;font-size:0.78rem;font-weight:600;}

/* ── TABS ── */
.tab-bar{display:flex;background:#fff;border-bottom:2px solid var(--border);overflow-x:auto;scrollbar-width:none;}
.tab-bar::-webkit-scrollbar{display:none;}
.tab-btn{flex:1;min-width:130px;height:var(--tab-h);padding:0 16px;border:none;background:none;font-family:'DM Sans',sans-serif;font-size:0.85rem;font-weight:500;color:var(--muted);cursor:pointer;border-bottom:3px solid transparent;transition:all .2s;white-space:nowrap;}
.tab-btn:hover{background:var(--accent-light);color:var(--accent);}
.tab-btn.active{color:var(--accent);border-bottom-color:var(--accent);font-weight:600;background:var(--accent-light);}
.tab-icon{display:block;font-size:1.1rem;margin-bottom:2px;}

/* ── PROGRESS ── */
.progress-wrap{height:5px;background:var(--border);}
.progress-bar{height:5px;background:linear-gradient(90deg,var(--accent),var(--highlight));transition:width .5s ease;width:0%;}

/* ── TAB CONTENT ── */
.tab-pane{display:none;}
.tab-pane.active{display:block;}

.container{max-width:880px;margin:0 auto;padding:28px 20px 60px;}

/* ── SCENARIO BOX ── */
.scenario{background:var(--card);border:1.5px solid var(--border);border-left:5px solid var(--accent);border-radius:8px;padding:20px 24px;margin-bottom:24px;line-height:1.65;font-size:0.95rem;}
.scenario strong{color:var(--accent2);}

/* ── FEED TABLE ── */
.feed-table{width:100%;border-collapse:collapse;font-size:0.85rem;margin-top:12px;font-family:'DM Mono',monospace;}
.feed-table th{background:var(--accent);color:#fff;padding:7px 10px;text-align:left;font-family:'DM Sans',sans-serif;font-weight:600;font-size:0.8rem;}
.feed-table td{padding:7px 10px;border-bottom:1px solid var(--border);}
.feed-table tr:last-child td{border-bottom:none;}
.feed-table tr:nth-child(even) td{background:rgba(0,0,0,0.02);}

/* ── STEP CARDS ── */
.step{background:var(--card);border:1.5px solid var(--border);border-radius:10px;margin-bottom:18px;overflow:hidden;transition:box-shadow .25s;}
.step.active{box-shadow:0 4px 20px rgba(61,107,79,0.15);border-color:var(--accent);}
.step.completed{border-color:var(--correct);}
.step.locked{opacity:.5;pointer-events:none;}
.step-header{display:flex;align-items:center;gap:12px;padding:14px 20px;}
.step-num{width:30px;height:30px;border-radius:50%;background:var(--accent);color:#fff;font-weight:700;font-size:0.88rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-family:'DM Mono',monospace;}
.step.completed .step-num{background:var(--correct);}
.step-title{font-family:'Lora',serif;font-weight:600;font-size:1rem;}
.step-status{margin-left:auto;font-size:1.1rem;}
.step-body{padding:0 20px 20px;border-top:1px solid var(--border);}

/* ── Q ROWS ── */
.q-row{margin-top:16px;}
.q-label{font-size:0.88rem;color:var(--muted);margin-bottom:6px;line-height:1.55;}
.q-label strong{color:var(--text);}
.input-row{display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
.ans-input{font-family:'DM Mono',monospace;font-size:.95rem;padding:7px 11px;border:2px solid var(--border);border-radius:6px;background:var(--bg);width:130px;color:var(--text);transition:border-color .2s;}
.ans-input:focus{outline:none;border-color:var(--accent);}
.ans-input.correct{border-color:var(--correct);background:var(--correct-light);}
.ans-input.wrong{border-color:var(--error);background:var(--error-light);}
.ans-input:disabled{opacity:.7;cursor:not-allowed;}
.unit-label{font-size:0.84rem;color:var(--muted);font-family:'DM Mono',monospace;}

/* ── BUTTONS ── */
.check-btn{padding:7px 16px;background:var(--accent);color:#fff;border:none;border-radius:6px;font-family:'DM Sans',sans-serif;font-weight:600;font-size:0.84rem;cursor:pointer;transition:background .2s,transform .1s;}
.check-btn:hover{background:#2d5a3f;}
.check-btn:active{transform:scale(.97);}
.next-btn{display:block;margin-top:16px;padding:9px 26px;background:var(--accent2);color:#fff;border:none;border-radius:7px;font-family:'DM Sans',sans-serif;font-weight:600;font-size:.92rem;cursor:pointer;transition:background .2s,transform .1s;width:fit-content;}
.next-btn:hover{background:#7a3a10;}
.next-btn:active{transform:scale(.97);}
.next-btn:disabled{opacity:.4;pointer-events:none;}
.hint-toggle{background:none;border:1.5px solid var(--highlight);color:var(--highlight);border-radius:5px;padding:5px 11px;font-size:0.8rem;cursor:pointer;font-family:'DM Sans',sans-serif;font-weight:600;transition:background .2s;}
.hint-toggle:hover{background:var(--highlight-light);}

/* ── FEEDBACK ── */
.feedback{margin-top:8px;font-size:0.86rem;padding:8px 12px;border-radius:6px;display:none;line-height:1.5;}
.feedback.show{display:block;}
.feedback.ok{background:var(--correct-light);color:var(--correct);}
.feedback.err{background:var(--error-light);color:var(--error);}
.feedback.hint{background:var(--highlight-light);color:#7a5c00;}

/* ── INFO BOX ── */
.info-box{background:var(--highlight-light);border-left:4px solid var(--highlight);border-radius:0 6px 6px 0;padding:11px 15px;font-size:0.86rem;line-height:1.6;margin-top:12px;color:#5a4800;}

/* ── DIVIDER ── */
.section-divider{border:none;border-top:1.5px dashed var(--border);margin:16px 0;}

/* ── PEARSON SQUARE ── */
.ps-outer{max-width:640px;margin:16px auto 0;}
.ps-grid{display:grid;grid-template-columns:155px 1fr 190px;align-items:stretch;gap:0;}
.ps-left{display:flex;flex-direction:column;justify-content:space-between;padding-right:10px;padding-top:12px;padding-bottom:12px;gap:10px;}
.ps-right{display:flex;flex-direction:column;justify-content:space-around;padding-left:10px;gap:8px;padding-top:12px;padding-bottom:12px;}
.ps-svg-wrap{position:relative;min-height:210px;}
.ps-svg-wrap svg{width:100%;height:100%;position:absolute;top:0;left:0;}
.ps-center{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);background:var(--card);border:2.5px solid var(--accent);border-radius:8px;padding:9px 13px;text-align:center;min-width:108px;box-shadow:0 2px 12px rgba(61,107,79,0.14);z-index:2;}
.ps-center .c-tag{font-size:0.67rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--accent);margin-bottom:3px;}
.ps-center .c-val{font-family:'DM Mono',monospace;font-size:1rem;font-weight:700;color:var(--accent);}
.ps-center .c-sub{font-size:0.68rem;color:var(--muted);margin-top:2px;font-style:italic;}
.ps-ing{background:var(--card);border:2px solid var(--accent2);border-radius:8px;padding:10px 12px;font-size:0.82rem;}
.ps-ing .i-tag{font-size:0.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:var(--accent2);margin-bottom:3px;}
.ps-ing .i-name{font-weight:600;color:var(--text);margin-bottom:2px;font-size:.83rem;}
.ps-ing .i-val{font-family:'DM Mono',monospace;font-size:.98rem;color:var(--accent2);font-weight:600;}
.ps-res{background:var(--card);border:2px solid var(--accent);border-radius:8px;padding:10px 12px;font-size:0.82rem;}
.ps-res .r-tag{font-size:0.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:var(--accent);margin-bottom:2px;}
.ps-res .r-eq{font-family:'DM Mono',monospace;font-size:.72rem;color:var(--muted);margin-bottom:5px;}
.ps-res-f{border-color:var(--highlight);}
.ps-res-f .r-tag{color:#7a5c00;}
.ps-box-input{font-family:'DM Mono',monospace;font-size:.9rem;padding:5px 7px;border:2px solid var(--border);border-radius:5px;background:var(--bg);width:100%;color:var(--text);transition:border-color .2s,background .2s;text-align:center;}
.ps-box-input:focus{outline:none;border-color:var(--accent);}
.ps-box-input.correct{border-color:var(--correct);background:var(--correct-light);}
.ps-box-input.wrong{border-color:var(--error);background:var(--error-light);}
.ps-box-input:disabled{opacity:.75;cursor:not-allowed;}

/* ── WORKED EXAMPLE CALLOUT ── */
.worked-step{background:var(--card);border:1.5px solid var(--border);border-radius:8px;padding:16px 20px;margin-bottom:14px;}
.worked-step h4{font-family:'Lora',serif;font-size:.95rem;color:var(--accent);margin-bottom:8px;}
.worked-step p,.worked-step li{font-size:.88rem;line-height:1.6;color:var(--muted);}
.worked-step strong{color:var(--text);}
.worked-step ol{padding-left:18px;margin-top:6px;}

/* ── COMPLETION ── */
.completion-banner{display:none;background:linear-gradient(135deg,var(--accent) 0%,#2d5a3f 100%);color:#fff;border-radius:10px;padding:28px;text-align:center;margin-top:24px;}
.completion-banner.show{display:block;animation:popIn .4s ease;}
.completion-banner h2{font-family:'Lora',serif;font-size:1.4rem;margin-bottom:8px;}
.completion-banner p{opacity:.9;font-size:.92rem;line-height:1.6;}
@keyframes popIn{from{transform:scale(.95);opacity:0;}to{transform:scale(1);opacity:1;}}

/* ── SHAKE ── */
@keyframes shake{0%,100%{transform:translateX(0);}20%{transform:translateX(-6px);}40%{transform:translateX(6px);}60%{transform:translateX(-4px);}80%{transform:translateX(4px);}}
.shake{animation:shake .35s ease;}

/* ── BULL SECTION HEADING ── */
.sq-heading{font-family:'Lora',serif;font-size:1.05rem;color:var(--accent2);margin:24px 0 12px;padding-bottom:6px;border-bottom:2px solid var(--border);}

/* ── MIX TABLE ── */
.mix-table{width:100%;border-collapse:collapse;font-size:.84rem;margin-top:10px;}
.mix-table th{background:#4a3520;color:#fff;padding:7px 10px;text-align:left;font-family:'DM Sans',sans-serif;font-weight:600;font-size:.78rem;}
.mix-table td{padding:7px 10px;border-bottom:1px solid var(--border);font-family:'DM Mono',monospace;}
.mix-table tr:last-child td{background:var(--accent-light);font-weight:600;font-family:'DM Sans',sans-serif;}

/* ── FREE SQUARE ── */
.free-section{background:var(--card);border:2px solid var(--highlight);border-radius:12px;overflow:hidden;margin-top:8px;}
.free-header{background:var(--highlight);padding:14px 22px;color:#fff;}
.free-header h3{font-family:'Lora',serif;font-size:1rem;font-weight:600;}
.free-body{padding:20px 22px;}
.free-scenario{background:var(--highlight-light);border-left:4px solid var(--highlight);border-radius:0 6px 6px 0;padding:11px 15px;margin-bottom:16px;font-size:.88rem;line-height:1.6;color:#5a4800;}

/* ── PRINT STYLES ── */
@media print {
  .tab-bar, .progress-wrap, #teachBanner, #teachModeBtn,
  #psIntro, .next-btn, .check-btn, .hint-toggle,
  .step.locked, .no-print { display: none !important; }
  .step { box-shadow: none !important; border: 1px solid #ccc !important; break-inside: avoid; }
  .step.active, .step.completed { display: block !important; }
  .tab-pane { display: block !important; }
  .tab-pane.print-hide { display: none !important; }
  body { background: #fff !important; font-size: 11pt; }
  .container { max-width: 100%; padding: 8px; }
  .header { padding: 12px 20px; print-color-adjust: exact; -webkit-print-color-adjust: exact; }
  .completion-banner { print-color-adjust: exact; -webkit-print-color-adjust: exact; break-inside: avoid; }
  .ps-svg-wrap { min-height: 160px; }
  .print-header { display: flex !important; }
  @page { margin: 1.5cm; }
}
.print-header { display: none; }

/* ── RESPONSIVE ── */
@media(max-width:600px){
  .ps-grid{grid-template-columns:120px 1fr 155px;}
  .tab-btn{min-width:100px;font-size:.78rem;padding:0 10px;}
  .header h1{font-size:1.2rem;}
}
</style>
</head>
<body>

<!-- HEADER -->
<!-- Print-only header strip (hidden on screen, shown on print) -->
<div class="print-header" style="border-bottom:2px solid #3d6b4f;padding:6px 20px;margin-bottom:8px;display:flex;justify-content:space-between;align-items:center;">
  <span style="font-weight:700;font-family:'DM Sans',sans-serif;font-size:11pt;">ANUT300/500 — Pearson Square Practical</span>
  <span id="print_namedate" style="font-size:10pt;font-family:'DM Mono',monospace;"></span>
</div>

<div class="header">
  <div class="header-inner">
    <div>
      <h1>🌾 Ration Formulation: Pearson Square</h1>
      <p>ANUT300/500 · Feedlot Ration Formulation Practical</p>
    </div>
    <button class="teach-btn" id="teachModeBtn" onclick="promptTeach()">🔐 Teaching Mode</button>
  </div>
</div>
<div id="teachBanner">
  <span>🎓 Teaching Mode active — all steps unlocked. Password required to enable.</span>
  <button class="teach-exit" onclick="exitTeach()">Exit Teaching Mode</button>
</div>

<!-- TABS -->
<div class="tab-bar">
  <button class="tab-btn active" onclick="switchTab('worked')" id="tab-worked">
    <span class="tab-icon">📖</span>Worked Example
  </button>
  <button class="tab-btn" onclick="switchTab('mare')" id="tab-mare">
    <span class="tab-icon">🐴</span>Q1: Mare
  </button>
  <button class="tab-btn" onclick="switchTab('bull')" id="tab-bull">
    <span class="tab-icon">🐂</span>Q2: Stud Bull
  </button>
  <button class="tab-btn" onclick="switchTab('free')" id="tab-free">
    <span class="tab-icon">✏️</span>Your Own Values
  </button>
</div>

<!-- INTRO DESCRIPTION -->
<div id="psIntro" style="background:#fffdf8;border-bottom:2px solid #d4c9b0;padding:16px 32px;">
  <div style="max-width:880px;margin:0 auto;">
    <details>
      <summary style="font-family:'Lora',serif;font-size:1rem;font-weight:600;color:#3d6b4f;cursor:pointer;user-select:none;list-style:none;display:flex;align-items:center;gap:8px;">
        <span id="introArrow" style="font-size:0.8rem;transition:transform .2s;">▶</span>
        <span>What is the Pearson Square method?</span>
      </summary>
      <div style="margin-top:14px;">

        <!-- Text explanation -->
        <p style="font-size:0.88rem;line-height:1.7;color:#5a4e40;margin-bottom:8px;">
          The <strong>Pearson Square</strong> is a method for balancing simple rations with two ingredients.
          You can use it when you want to substitute between ingredients to meet an animal's nutrient requirement.
          The square tells you what <strong>mix of two ingredients</strong> will give the right nutrient content in the final ration.
          Ingredients must be compared on a <strong>like basis</strong> (both DM or both as-fed).
          The method works for any nutrient: CP, energy, amino acids, minerals, etc.
        </p>
        <p style="font-size:0.85rem;line-height:1.6;color:#7a6e5f;margin-bottom:14px;font-style:italic;">
          One ingredient must have a nutrient value above the target (Box A) and one below it — it does not matter which sits top or bottom on the square.
          Always make any negative numbers positive: we are interested in the <em>difference</em> between A&amp;B or A&amp;C only.
        </p>

        <!-- Diagram — simple clean grid, no absolute positioning -->
        <div style="display:grid;grid-template-columns:150px 1fr 165px;grid-template-rows:auto auto;gap:10px;max-width:560px;align-items:stretch;margin-bottom:12px;">

          <!-- Row 1 left: Box B -->
          <div style="background:#fffdf8;border:2px solid #8b4513;border-radius:8px;padding:10px 12px;font-size:0.82rem;grid-row:1/2;grid-column:1/2;">
            <div style="font-size:0.67rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:#8b4513;margin-bottom:3px;">Box B</div>
            <div style="font-weight:600;color:#2a2318;margin-bottom:2px;">Ingredient 1</div>
            <div style="font-family:'DM Mono',monospace;color:#8b4513;font-size:0.82rem;">nutrient value %</div>
          </div>

          <!-- Row 1 centre: SVG square spanning both rows -->
          <div style="grid-row:1/3;grid-column:2/3;position:relative;min-height:180px;">
            <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%;position:absolute;top:0;left:0;">
              <rect x="4" y="4" width="192" height="192" fill="none" stroke="#5a8c72" stroke-width="2.5" rx="4"/>
              <line x1="4" y1="4" x2="196" y2="196" stroke="#5a8c72" stroke-width="2"/>
              <polygon points="196,196 182,188 188,182" fill="#5a8c72"/>
              <line x1="4" y1="196" x2="196" y2="4" stroke="#5a8c72" stroke-width="2"/>
              <polygon points="196,4 182,12 188,18" fill="#5a8c72"/>
            </svg>
            <!-- Box A sits in the centre using flex rather than absolute -->
            <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);background:#fffdf8;border:2.5px solid #3d6b4f;border-radius:8px;padding:9px 12px;text-align:center;width:110px;z-index:2;box-shadow:0 2px 8px rgba(61,107,79,0.12);">
              <div style="font-size:0.65rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#3d6b4f;margin-bottom:3px;">Box A</div>
              <div style="font-family:'DM Mono',monospace;font-size:0.88rem;font-weight:700;color:#3d6b4f;">Target %</div>
              <div style="font-size:0.65rem;color:#7a6e5f;margin-top:2px;font-style:italic;">between B &amp; C</div>
            </div>
          </div>

          <!-- Row 1 right: Box D and Box F stacked -->
          <div style="grid-row:1/2;grid-column:3/4;display:flex;flex-direction:column;gap:8px;">
            <div style="background:#fffdf8;border:2px solid #3d6b4f;border-radius:8px;padding:9px 11px;font-size:0.8rem;flex:1;">
              <div style="font-size:0.65rem;font-weight:700;text-transform:uppercase;color:#3d6b4f;margin-bottom:2px;">Box D</div>
              <div style="font-family:'DM Mono',monospace;color:#7a6e5f;font-size:0.75rem;">= |A − C|</div>
              <div style="color:#5a4e40;font-size:0.75rem;margin-top:2px;">parts of ingr. 1</div>
            </div>
            <div style="background:#fffdf8;border:2px solid #c9a84c;border-radius:8px;padding:9px 11px;font-size:0.8rem;flex:1;">
              <div style="font-size:0.65rem;font-weight:700;text-transform:uppercase;color:#7a5c00;margin-bottom:2px;">Box F</div>
              <div style="font-family:'DM Mono',monospace;color:#7a6e5f;font-size:0.75rem;">= D + E</div>
              <div style="color:#5a4e40;font-size:0.75rem;margin-top:2px;">total parts</div>
            </div>
          </div>

          <!-- Row 2 left: Box C -->
          <div style="background:#fffdf8;border:2px solid #8b4513;border-radius:8px;padding:10px 12px;font-size:0.82rem;grid-row:2/3;grid-column:1/2;">
            <div style="font-size:0.67rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:#8b4513;margin-bottom:3px;">Box C</div>
            <div style="font-weight:600;color:#2a2318;margin-bottom:2px;">Ingredient 2</div>
            <div style="font-family:'DM Mono',monospace;color:#8b4513;font-size:0.82rem;">nutrient value %</div>
          </div>

          <!-- Row 2 right: Box E -->
          <div style="background:#fffdf8;border:2px solid #3d6b4f;border-radius:8px;padding:9px 11px;font-size:0.8rem;grid-row:2/3;grid-column:3/4;">
            <div style="font-size:0.65rem;font-weight:700;text-transform:uppercase;color:#3d6b4f;margin-bottom:2px;">Box E</div>
            <div style="font-family:'DM Mono',monospace;color:#7a6e5f;font-size:0.75rem;">= |B − A|</div>
