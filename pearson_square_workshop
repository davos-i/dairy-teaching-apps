function forceUnlock(prefix, n, _) {
  const el=document.getElementById(prefix+'step'+n);
  if (!el) return;
  el.classList.remove('locked');
  if (!el.classList.contains('completed')) el.classList.add('active');
  const st=document.getElementById(prefix+'status'+n);
  if (st&&st.textContent==='🔒') st.textContent='🔓';
}

function exitTeach() {
  // Restore each tab to its original load state:
  // step 1 = active/unlocked, steps 2+ = locked (unless genuinely completed)
  ['w','m','b'].forEach(p=>{
    const max=p==='w'?3:p==='m'?8:9;
    for(let i=1;i<=max;i++){
      const el=document.getElementById(p+'step'+i);
      if(!el)continue;
      const st=document.getElementById(p+'status'+i);
      if(!st)continue;
      // Skip genuinely completed steps (they have ✅)
      if(st.textContent==='✅') continue;
      if(i===1){
        // Step 1 should always be active and unlocked
        el.classList.remove('locked','completed');
        el.classList.add('active');
        st.textContent='🔓';
        // Don't disable next button for step 1 if it was already enabled before teach mode
      } else {
        // Steps 2+ should be locked unless completed
        el.classList.add('locked');
        el.classList.remove('active','completed');
        st.textContent='🔒';
        const prefix = p==='w'?'w':p==='m'?'m':'b';
        const nb=document.getElementById(prefix+'next'+i);
        if(nb)nb.disabled=true;
      }
    }
  });
  document.getElementById('teachBanner').style.display='none';
  document.getElementById('teachModeBtn').style.display='inline-block';
}


